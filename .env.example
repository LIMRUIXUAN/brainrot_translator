OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_VISION_MODEL=google/gemini-3-flash-preview
OPENROUTER_VISION_FALLBACK_MODELS=openai/gpt-4o,anthropic/claude-3-5-sonnet
OPENROUTER_HTTP_REFERER=https://brainrot-translator.local
OPENROUTER_APP_TITLE=Brainrot Translator

BRAINROT_API_BASE_URL=http://127.0.0.1:8000
BRAINROT_LOW_CONFIDENCE_THRESHOLD=0.7
BRAINROT_MAX_IMAGE_BYTES=5242880
ENABLE_LOCAL_TRANSLATION_STUB=true

DATABASE_URL=
REQUEST_DELAY_SECONDS=1.5
